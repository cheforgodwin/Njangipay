rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }

    function isCommunityAdmin(communityId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/communities/$(communityId)).data.admin_id == request.auth.uid ||
        isSuperAdmin()
      );
    }

    function isGroupLeader(groupId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/groups/$(groupId)).data.leader_id == request.auth.uid ||
        isSuperAdmin()
      );
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || isSuperAdmin();
    }

    // Communities
    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow write: if isCommunityAdmin(communityId);
    }

    // Sub-Communities
    match /sub_communities/{subCommunityId} {
      allow read: if isSignedIn();
      allow write: if isCommunityAdmin(resource.data.community_id);
    }

    // Groups
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        resource.data.admin_id == request.auth.uid || 
        isSuperAdmin() ||
        isGroupLeader(groupId)
      );
    }

    // Group Members
    match /members/{memberId} {
      allow read: if isSignedIn() && (
        resource.data.user_id == request.auth.uid ||
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
      allow write: if isSignedIn() && (
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
    }

    // Contributions
    match /contributions/{contributionId} {
      allow read: if isSignedIn() && (
        resource.data.user_id == request.auth.uid ||
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
      allow write: if isSignedIn() && (
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
    }

    // Loans
    match /loans/{loanId} {
      allow read: if isSignedIn() && (
        resource.data.borrower_id == request.auth.uid ||
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
      allow write: if isSignedIn() && (
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
    }

    // Rotation
    match /rotation/{rotationId} {
      allow read: if isSignedIn() && (
        resource.data.member_id == request.auth.uid ||
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
      allow write: if isSignedIn() && (
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
    }

    // Audit Logs
    match /audit_logs/{auditId} {
      allow read: if isSignedIn() && (
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
      allow create: if isSignedIn();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.user_id == request.auth.uid ||
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
      allow write: if isSignedIn();
    }

    // Meetings
    match /meetings/{meetingId} {
      allow read: if isSignedIn() && (
        resource.data.group_id in get(/databases/$(database)/documents/members/$(request.auth.uid)).data.group_ids ||
        isSuperAdmin()
      );
      allow write: if isSignedIn() && (
        isGroupLeader(resource.data.group_id) ||
        isSuperAdmin()
      );
    }

    
    // Transactions
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isGroupLeader(resource.data.group_id) || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.user_id == request.auth.uid || isSuperAdmin());
      allow update, delete: if isSuperAdmin(); 
    }

    // Global System Events & Config (Super Admin Only)
    match /system_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /system_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
